# DocuForge Backend Environment Variables
# Copy this file to .env and configure your values

# ===========================================
# Application
# ===========================================
PROJECT_NAME=DocuForge
DEBUG=False
API_V1_STR=/api/v1

# ===========================================
# Security
# ===========================================
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql+asyncpg://docuforge:docuforge123@localhost:5432/docuforge
DATABASE_URL_SYNC=postgresql://docuforge:docuforge123@localhost:5432/docuforge
# Docker: DATABASE_URL=postgresql+asyncpg://docuforge:docuforge123@db:5432/docuforge

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379/0
# Docker: REDIS_URL=redis://redis:6379/0

# ===========================================
# Celery
# ===========================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===========================================
# File Storage
# ===========================================
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=storage/uploads
PROCESSED_DIR=storage/processed
TEMP_DIR=storage/temp
FILE_RETENTION_HOURS=24

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ===========================================
# NOTE: AI configuration removed from template
# To re-enable AI features, add appropriate API keys and settings manually.
# ===========================================
# NOTE: OCR configuration removed from template
# To re-enable OCR, add TESSERACT_PATH and DEFAULT_OCR_LANGUAGE manually.
# ===========================================
# Cloud Storage (Optional)
# ===========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_REQUESTS_PER_DAY=1000
